# Stage 1: Build the React SPA
FROM node:22-slim AS builder

WORKDIR /build/client

# Copy client source and force a clean linux-native npm install.
# The macOS package-lock.json omits linux/arm64 optional packages
# (npm bug github.com/npm/cli/issues/4828); deleting it before
# install ensures npm resolves the correct platform binaries.
COPY client/ ./
RUN rm -rf node_modules package-lock.json && npm install

# Build the production bundle
RUN npm run build

# Stage 2: Serve with nginx
FROM nginx:stable-alpine

COPY --from=builder /build/client/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

# nginx starts as root to bind port 80, then drops to the
# nginx user for worker processes via its own configuration.
CMD ["nginx", "-g", "daemon off;"]
