#
# This is a sample configuration file for the pgEdge AI Workbench.
# Copy this file to ai-workbench.conf and customize it for your environment.
#
# Configuration options can be set here or overridden via command line flags.
# Command line flags take precedence over configuration file settings.
#
# Lines beginning with # are comments.
# Format: key = value
#

#
# AI Workbench Datastore Connection Settings
#
# IMPORTANT: These settings configure the connection to the AI Workbench's
# own PostgreSQL datastore database. This is NOT the connection information
# for the PostgreSQL servers you want to monitor.
#
# The datastore is a PostgreSQL database used by AI Workbench to store:
# - Monitoring data collected from your PostgreSQL servers
# - Connection information for monitored servers
# - User accounts and authentication tokens
# - Probe configurations and other system data
#
# These settings are used by both the collector and the MCP server components.
#
# Connection information for the PostgreSQL servers you want to MONITOR is
# configured separately through the MCP server API or directly in the
# datastore's monitored_connections table.
#

# Hostname or IP address of the AI Workbench datastore PostgreSQL server
pg_host = localhost

# IP address of the AI Workbench datastore server (optional, bypasses DNS)
# pg_hostaddr = 127.0.0.1

# Database name in the AI Workbench datastore
pg_database = ai_workbench

# Username for connecting to the AI Workbench datastore
pg_username = postgres

# Path to file containing the password for the AI Workbench datastore
# The file should contain only the password with no extra whitespace
# pg_password_file = /path/to/password.txt

# Port on which the AI Workbench datastore is listening
pg_port = 5432

# SSL mode for the AI Workbench datastore connection
# Options: disable, allow, prefer, require, verify-ca, verify-full
pg_sslmode = prefer

# Path to client SSL certificate for the AI Workbench datastore (optional)
# pg_sslcert = /path/to/client-cert.pem

# Path to client SSL key for the AI Workbench datastore (optional)
# pg_sslkey = /path/to/client-key.pem

# Path to root SSL certificate for the AI Workbench datastore (optional)
# pg_sslrootcert = /path/to/ca-cert.pem

#
# Connection Pool Settings
#
# The connection pool manages database connections to the AI Workbench datastore.
# These settings control how connections are created, reused, and cleaned up.
#

# Maximum number of concurrent connections to the datastore
# This limits the total number of open connections at any time
# Default: 25
# pool_max_connections = 25

# Maximum idle time for connections in seconds
# Connections that have been idle (returned to the pool but not reused) for
# longer than this duration will be automatically closed to free resources.
# Set to 0 to disable automatic cleanup of idle connections.
# Default: 300 (5 minutes)
# pool_max_idle_seconds = 300

#
# Security Settings
#

# Server secret for encryption (REQUIRED)
# This secret is used to encrypt sensitive data such as passwords for
# monitored connections. Generate a strong random string for production use.
# WARNING: Keep this secret secure and do not share it.
server_secret = CHANGE-ME-TO-A-RANDOM-SECRET-STRING

# Maximum lifetime for user-owned API tokens in days
# Users can create tokens for command-line and programmatic access to the
# MCP server. This setting controls the maximum lifetime they can specify.
# Set to 0 to allow users to create tokens with indefinite lifetime.
# Default: 90 days
# max_user_token_lifetime_days = 90

#
# MCP Server Settings (used by the server component only)
#

# Enable HTTPS/TLS mode for the MCP server
# Set to true for production deployments
# tls = false

# Path to TLS certificate file
# Required when tls = true
# tls_cert = /path/to/server-cert.pem

# Path to TLS private key file
# Required when tls = true
# tls_key = /path/to/server-key.pem

# Path to TLS certificate chain file (optional)
# tls_chain = /path/to/cert-chain.pem

#
# Collector Settings (used by the collector component only)
#

# Additional collector-specific settings may be added here in the future
